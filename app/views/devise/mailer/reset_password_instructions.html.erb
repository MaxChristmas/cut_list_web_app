<% scope = "devise.mailer.reset_password_instructions" %>

<h1 style="margin: 0 0 24px; font-size: 26px; font-weight: 700; color: #1a1a2e; text-align: center;">
  <%= t("#{scope}.title") %>
</h1>

<p style="margin: 0 0 8px; font-size: 15px; color: #4a5568; text-align: center; font-weight: 600;">
  <%= t("#{scope}.instruction") %>
</p>

<p style="margin: 0 0 24px; font-size: 15px; color: #4a5568; text-align: center;">
  <%= t("#{scope}.instruction_2") %>
</p>

<%# CTA Button %>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td align="center" style="padding-bottom: 24px;">
      <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>"
         style="display: inline-block; padding: 14px 36px; background-color: #4C9FE7; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 6px;">
        <%= t("#{scope}.action") %>
      </a>
    </td>
  </tr>
</table>

<p style="margin: 0 0 24px; font-size: 14px; color: #4C9FE7; text-align: center;">
  <%= mail_to @resource.email, t("#{scope}.email_label", email: @resource.email), style: "color: #4C9FE7; text-decoration: none;" %>
</p>

<p style="margin: 0; font-size: 14px; color: #9ca3af; text-align: center;">
  <%= t("#{scope}.instruction_3") %>
</p>
