<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="backdrop:bg-black/50 bg-transparent p-0 m-0 md:m-auto open:flex md:items-center md:justify-center fixed inset-0 w-full h-full max-w-none max-h-none md:w-100 md:h-fit md:max-h-[90vh]">
  <div class="bg-gray-950 md:border md:border-gray-700 md:rounded-xl p-10 w-full h-full md:h-auto shadow-xl overflow-y-auto relative">
    <%# Close button %>
    <button data-action="click->modal#close"
            class="absolute top-4 right-4 p-1 rounded-md hover:bg-gray-800 text-gray-400 hover:text-white transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
      </svg>
    </button>

    <%# Logo %>
    <% logo_locale_modal = { en: "en", fr: "fr", ja: "jp", es: "es" }.fetch(I18n.locale, "en") %>
    <div class="flex justify-center mb-6">
      <%= image_tag "cutoptima-logo-dark-#{logo_locale_modal}.svg", alt: t("app_name"), class: 'h-10 w-auto' %>
    </div>

    <%# Tab header %>
    <div class="mb-4">
      <div class="flex gap-4 border-b border-gray-800 pb-0">
        <button data-modal-target="tab" data-tab="sign_in" data-action="click->modal#switchTab"
                class="pb-3 text-sm font-medium border-b-2 border-white text-white transition-colors">
          <%= t("sidebar.sign_in") %>
        </button>
        <button data-modal-target="tab" data-tab="sign_up" data-action="click->modal#switchTab"
                class="pb-3 text-sm font-medium border-b-2 border-transparent text-gray-500 transition-colors">
          <%= t("login.sign_up") %>
        </button>
        <button data-modal-target="tab" data-tab="forgot_password" data-action="click->modal#switchTab"
                class="hidden pb-3 text-sm font-medium border-b-2 border-transparent text-gray-500 transition-colors">
          <%= t("login.forgot_password") %>
        </button>
      </div>
    </div>

    <%# Promo message (shown when auto-opened from limit) %>
    <div data-modal-target="promo" class="hidden p-3 bg-indigo-900/50 text-indigo-200 rounded text-sm mb-2"></div>

    <%# Error message %>
    <div data-modal-target="error" data-fallback="<%= t('login.invalid_credentials') %>"
         class="hidden p-3 bg-red-900/50 text-red-300 rounded text-sm"></div>

    <%# Success message (for password reset) %>
    <div data-modal-target="success"
         class="hidden p-3 bg-green-900/50 text-green-300 rounded text-sm">
      <%= t("login.reset_password_sent") %>
    </div>

    <%# Sign In panel — vertical layout %>
    <div data-modal-target="panel" data-tab="sign_in" class="pt-4">
      <%# Google OAuth %>
      <div>
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
              class: "w-full flex items-center justify-center gap-3 bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors" do %>
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A11.96 11.96 0 0 0 1 12c0 1.94.46 3.77 1.18 5.07l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <%= t("login.sign_in_with_google") %>
        <% end %>
      </div>

      <%# Divider %>
      <div class="flex items-center gap-3 py-4">
        <div class="flex-1 border-t border-gray-800"></div>
        <span class="text-xs text-gray-500"><%= t("login.or") %></span>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>

      <%# Email/password form %>
      <%= form_for(User.new, as: :user, url: user_session_path, html: { class: "space-y-5", data: { action: "submit->modal#submitForm", turbo: false } }) do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2"><%= t("settings.email") %></label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-100 text-sm focus:outline-none focus:ring-1 focus:ring-gray-600" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2"><%= t("login.password") %></label>
          <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-100 text-sm focus:outline-none focus:ring-1 focus:ring-gray-600" %>
        </div>

        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-gray-700 bg-gray-900 text-white focus:ring-gray-600" %>
          <label class="text-sm text-gray-400"><%= t("login.remember_me") %></label>
        </div>

        <button type="submit"
                class="w-full bg-white text-gray-950 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-200 transition-colors text-sm">
          <%= t("sidebar.sign_in") %>
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <button data-action="click->modal#showForgotPassword"
                class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          <%= t("login.forgot_password") %>
        </button>
      </div>
    </div>

    <%# Forgot Password panel %>
    <div data-modal-target="panel" data-tab="forgot_password" class="hidden pt-4">
      <p class="text-sm text-gray-400 mb-4"><%= t("login.forgot_password_instructions") %></p>

      <%= form_for(User.new, as: :user, url: user_password_path, html: { class: "space-y-5", data: { action: "submit->modal#submitPasswordReset", turbo: false } }) do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2"><%= t("settings.email") %></label>
          <%= f.email_field :email, autocomplete: "email",
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-100 text-sm focus:outline-none focus:ring-1 focus:ring-gray-600" %>
        </div>

        <button type="submit"
                class="w-full bg-white text-gray-950 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-200 transition-colors text-sm">
          <%= t("login.send_reset_instructions") %>
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <button data-action="click->modal#showSignIn"
                class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          <%= t("login.back_to_sign_in") %>
        </button>
      </div>
    </div>

    <%# Sign Up panel — vertical layout %>
    <div data-modal-target="panel" data-tab="sign_up" class="hidden pt-4">
      <%# Google OAuth %>
      <div>
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
              class: "w-full flex items-center justify-center gap-3 bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors" do %>
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A11.96 11.96 0 0 0 1 12c0 1.94.46 3.77 1.18 5.07l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <%= t("login.sign_in_with_google") %>
        <% end %>
        <p class="text-xs text-gray-500 text-center mt-2">
          <%= t("login.google_terms_html",
                privacy_link: link_to(t("privacy_policy.link"), privacy_policy_path, class: "text-blue-400 hover:text-blue-300 underline", target: "_blank"),
                legal_link: link_to(t("legal_notices.link"), legal_notices_path, class: "text-blue-400 hover:text-blue-300 underline", target: "_blank")) %>
        </p>
      </div>

      <%# Divider %>
      <div class="flex items-center gap-3 py-4">
        <div class="flex-1 border-t border-gray-800"></div>
        <span class="text-xs text-gray-500"><%= t("login.or") %></span>
        <div class="flex-1 border-t border-gray-800"></div>
      </div>

      <%# Email/password form %>
      <%= form_for(User.new, as: :user, url: user_registration_path, html: { class: "space-y-5", data: { action: "submit->modal#submitForm", turbo: false } }) do |f| %>
        <%# Honeypot field — invisible to humans, bots will fill it %>
        <div aria-hidden="true" style="position:absolute;left:-9999px">
          <%= text_field_tag :website, nil, tabindex: "-1", autocomplete: "off" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2"><%= t("settings.email") %></label>
          <%= f.email_field :email, autocomplete: "email",
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-100 text-sm focus:outline-none focus:ring-1 focus:ring-gray-600" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2"><%= t("login.password") %></label>
          <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-gray-100 text-sm focus:outline-none focus:ring-1 focus:ring-gray-600" %>
        </div>

        <div class="flex items-start gap-2">
          <%= f.check_box :terms_accepted, class: "mt-0.5 rounded border-gray-700 bg-gray-900 text-white focus:ring-gray-600" %>
          <label class="text-xs text-gray-400">
            <%= t("login.terms_html",
                  privacy_link: link_to(t("privacy_policy.link"), privacy_policy_path, class: "text-blue-400 hover:text-blue-300 underline", target: "_blank"),
                  legal_link: link_to(t("legal_notices.link"), legal_notices_path, class: "text-blue-400 hover:text-blue-300 underline", target: "_blank")) %>
          </label>
        </div>

        <button type="submit"
                class="w-full bg-white text-gray-950 font-semibold py-2.5 px-4 rounded-lg hover:bg-gray-200 transition-colors text-sm">
          <%= t("login.sign_up") %>
        </button>
      <% end %>
    </div>
  </div>
</dialog>
