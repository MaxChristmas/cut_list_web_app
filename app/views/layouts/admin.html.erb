<!DOCTYPE html>
<html>
  <head>
    <title>Admin - Cut List Web App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="flex min-h-screen" data-controller="sidebar">

      <!-- Mobile overlay -->
      <div
        data-sidebar-target="overlay"
        data-action="click->sidebar#closeMobile"
        class="hidden fixed inset-0 z-20 bg-black/40 md:hidden"
      ></div>

      <!-- Sidebar -->
      <aside
        data-sidebar-target="sidebar"
        class="fixed inset-y-0 left-0 z-30 w-56 bg-white border-r border-gray-200 flex flex-col max-md:-translate-x-full transition-transform duration-200 md:static md:translate-x-0"
      >
        <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
          <h1 class="text-lg font-semibold text-gray-900">Admin Panel</h1>
          <!-- Close button (mobile only) -->
          <button
            type="button"
            data-action="click->sidebar#closeMobile"
            class="md:hidden -mr-1 p-1 rounded text-gray-500 hover:text-gray-700 hover:bg-gray-100"
            aria-label="Close menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1">
          <%= admin_nav_link "Dashboard", admin_root_path, "dashboard" %>
          <%= admin_nav_link "Users", admin_users_path, "users" %>
          <%= admin_nav_link "Projects", admin_projects_path, "projects" %>
          <%= admin_nav_link "Reports", admin_report_issues_path, "report_issues" %>
          <%= admin_nav_link "Feedbacks", admin_feedbacks_path, "feedbacks", badge_count: @unread_feedbacks_count %>
          <%= admin_nav_link "Coupons", admin_coupons_path, "coupons" %>
          <%= admin_nav_link "Scan Tokens", admin_scan_tokens_path, "scan_tokens" %>
        </nav>
        <div class="px-3 py-4 border-t border-gray-200">
          <div class="text-xs text-gray-500 mb-2"><%= current_admin_user.email %></div>
          <%= button_to "Sign out", destroy_admin_user_session_path, method: :delete, class: "text-sm text-red-600 hover:text-red-800" %>
        </div>
      </aside>

      <!-- Main content wrapper (takes remaining space on desktop) -->
      <div class="flex flex-col flex-1 min-w-0 md:ml-0">

        <!-- Mobile top bar -->
        <header class="md:hidden sticky top-0 z-10 bg-white border-b border-gray-200 flex items-center px-4 py-3 gap-3">
          <button
            type="button"
            data-action="click->sidebar#toggleMobile"
            class="p-1.5 rounded text-gray-600 hover:text-gray-900 hover:bg-gray-100"
            aria-label="Open menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <span class="text-sm font-semibold text-gray-900">Admin Panel</span>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-4 md:p-8">
          <% if notice.present? %>
            <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-green-800 text-sm"><%= notice %></div>
          <% end %>
          <% if alert.present? %>
            <div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm"><%= alert %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>

    </div>
  </body>
</html>
