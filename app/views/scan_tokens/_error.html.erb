<div id="scan_photo_preview">
  <div class="text-center space-y-4">
    <div class="w-14 h-14 mx-auto rounded-full bg-red-900/40 flex items-center justify-center">
      <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-red-400"><%= message %></p>
      <p class="text-xs text-gray-500 mt-1"><%= t("scan.try_again") %></p>
    </div>
    <button type="button"
            onclick="document.getElementById('photo-import-modal').classList.add('hidden'); document.getElementById('photo-import-modal').classList.remove('flex'); document.getElementById('photo-import-trigger')?.click();"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-gray-700 hover:bg-gray-600 text-gray-200 border border-gray-600 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182"/>
      </svg>
      <%= t("scan.retry") %>
    </button>
  </div>
</div>
