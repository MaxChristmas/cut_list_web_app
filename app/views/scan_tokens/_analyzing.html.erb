<div id="scan_photo_preview">
  <div class="text-center space-y-2">
    <h3 class="text-base font-semibold"><%= t("scan.analyzing_title") %></h3>
    <p class="text-xs text-gray-400"><%= t("scan.analyzing_message") %></p>
  </div>

  <div class="relative mx-auto w-56 h-56 mt-4">
    <%# Greyed-out QR code placeholder %>
    <div class="w-full h-full bg-gray-700/50 rounded-xl flex items-center justify-center">
      <div class="text-center space-y-3">
        <div class="inline-block w-8 h-8 border-2 border-blue-400 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-xs text-gray-400"><%= t("scan.analyzing_image") %></p>
      </div>
    </div>
  </div>
</div>
