<div data-controller="photo-import" data-photo-import-scan-token-id-value="<%= scan_token.id %>" class="space-y-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2 text-green-400 text-sm font-medium">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
      </svg>
      <span><%= t("scan.pieces_found", count: pieces.sum { |p| (p["quantite"] || 1).to_i }) %></span>
    </div>
    <% if Rails.env.development? %>
      <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full <%= scan_token.ai_provider == 'openai' ? 'bg-green-900/50 text-green-400' : 'bg-purple-900/50 text-purple-400' %>">
        <%= scan_token.ai_provider == "openai" ? "GPT-4o" : "Claude" %>
      </span>
    <% end %>
  </div>

  <div class="max-h-64 overflow-y-auto">
    <table class="w-full text-left text-sm">
      <thead>
        <tr class="border-b border-gray-700 text-gray-400">
          <th class="py-1 pr-2 font-light"><%= t("scan.piece_name") %></th>
          <th class="py-1 pr-2 font-light"><%= t("projects.index.length_short") %></th>
          <th class="py-1 pr-2 font-light"><%= t("projects.index.width_short") %></th>
          <th class="py-1 pr-2 font-light w-16"><%= t("projects.index.quantity_short") %></th>
          <th class="py-1 w-8 font-light"></th>
          <th class="py-1 w-8 font-light"></th>
        </tr>
      </thead>
      <tbody data-photo-import-target="tbody">
        <% pieces.each_with_index do |piece, i| %>
          <% confidence = piece["confiance"] || "haute" %>
          <% confidence_class = case confidence
               when "haute" then ""
               when "moyenne" then "border-l-2 border-yellow-500"
               when "basse" then "border-l-2 border-red-500"
             end %>
          <% badge_class = case confidence
               when "haute" then "bg-green-900/50 text-green-400"
               when "moyenne" then "bg-yellow-900/50 text-yellow-400"
               when "basse" then "bg-red-900/50 text-red-400"
             end %>
          <tr class="border-b border-gray-800 <%= confidence_class %>"
              data-photo-import-target="row"
              data-confidence="<%= confidence %>">
            <td class="py-1.5 pr-2">
              <input type="text" value="<%= piece["nom"] %>"
                     data-field="label"
                     class="w-full bg-gray-700 border border-gray-700 rounded px-1.5 py-0.5 text-xs text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500">
            </td>
            <td class="py-1.5 pr-2">
              <input type="number" value="<%= piece["longueur"] %>" step="any" min="1"
                     data-field="length"
                     data-action="input->photo-import#onEdit"
                     class="w-full bg-gray-700 border border-gray-700 rounded px-1.5 py-0.5 text-xs text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500">
            </td>
            <td class="py-1.5 pr-2">
              <input type="number" value="<%= piece["largeur"] %>" step="any" min="1"
                     data-field="width"
                     data-action="input->photo-import#onEdit"
                     class="w-full bg-gray-700 border border-gray-700 rounded px-1.5 py-0.5 text-xs text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500">
            </td>
            <td class="py-1.5 pr-2">
              <input type="number" value="<%= piece["quantite"] || 1 %>" min="1"
                     data-field="quantity"
                     data-action="input->photo-import#onEdit"
                     class="w-full bg-gray-700 border border-gray-700 rounded px-1.5 py-0.5 text-xs text-gray-200 focus:outline-none focus:ring-1 focus:ring-blue-500">
            </td>
            <td class="py-1.5 text-center">
              <% unless confidence == "haute" %>
                <span class="inline-block text-[10px] px-1.5 py-0.5 rounded-full font-medium <%= badge_class %>">
                  <%= confidence == "moyenne" ? "moy" : "bas" %>
                </span>
              <% end %>
            </td>
            <td class="py-1.5 text-center">
              <button type="button" data-action="photo-import#removeRow"
                      class="text-red-400 hover:text-red-300 text-xs font-medium">&times;</button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <button type="button" data-action="photo-import#addRow"
          class="text-sm text-white hover:text-gray-300 font-medium">
    <%= t("projects.index.add_piece") %>
  </button>

  <% has_low_confidence = pieces.any? { |p| p["confiance"] == "basse" } %>
  <p data-photo-import-target="warning"
     class="<%= 'hidden' unless has_low_confidence %> text-xs text-red-400">
    <%= t("scan.low_confidence_warning") %>
  </p>

  <p data-photo-import-target="dimensionError" class="hidden text-xs text-red-400">
    <%= t("optimizer_errors.length_less_than_width") %>
  </p>

  <button type="button"
          data-action="photo-import#addToProject"
          data-photo-import-target="addButton"
          <%= "disabled" if has_low_confidence %>
          class="w-full py-2 px-4 rounded-lg font-medium text-sm bg-white text-gray-950 hover:bg-gray-200 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
    <%= t("scan.add_to_project") %>
  </button>
</div>
