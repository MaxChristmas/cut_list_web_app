<div class="h-full overflow-y-auto bg-gray-950 text-gray-300">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <% if alert.present? %>
      <div class="p-3 mb-6 bg-red-900/50 text-red-300 rounded text-sm"><%= alert %></div>
    <% end %>
    <% if notice.present? %>
      <div class="p-3 mb-6 bg-green-900/50 text-green-300 rounded text-sm"><%= notice %></div>
    <% end %>

    <div class="text-center mb-10">
      <h1 class="text-2xl font-bold text-white"><%= t("plans.title") %></h1>
      <p class="text-gray-400 mt-2"><%= t("plans.subtitle") %></p>
    </div>

    <% worker_config = Plannable::PLANS["worker"] %>
    <% free_features = Plannable::PLANS["free"][:features] %>
    <% paid_only_features = worker_config[:features] - free_features - %i[margin archive] %>
    <% is_current_worker = @current_plan == "worker" %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      <%# Left card: Accès 3 jours (one-shot) %>
      <% one_shot_price = worker_config[:prices][:one_shot] %>
      <div class="rounded-xl border border-gray-700 bg-gray-900 p-6 flex flex-col">
        <h2 class="text-lg font-bold text-white mb-1"><%= t("plans.one_shot.name") %></h2>
        <p class="text-sm text-gray-400 mb-6"><%= t("plans.one_shot.description") %></p>

        <div class="mb-6">
          <span class="text-3xl font-bold text-white"><%= number_with_precision(one_shot_price[:amount] / 100.0, precision: 2, strip_insignificant_zeros: true) %>&euro;</span>
          <span class="text-gray-400 text-sm"><%= t("plans.tax_label") %></span>
        </div>

        <ul class="space-y-3 flex-1 mb-6">
          <li class="flex items-center gap-3 text-sm">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-gray-300"><%= t("plans.one_shot.full_access") %></span>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-gray-300"><%= t("plans.one_shot.no_subscription") %></span>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span class="text-gray-300"><%= t("plans.one_shot.duration") %></span>
          </li>
        </ul>

        <% if user_signed_in? %>
          <%= form_with url: plan_checkout_path, method: :post, class: "w-full mt-auto" do |f| %>
            <%= f.hidden_field :plan, value: "worker" %>
            <%= f.hidden_field :billing_cycle, value: "one_shot" %>
            <%= f.submit t("plans.one_shot.access_now"),
                  class: "w-full py-2 rounded text-center text-sm font-medium cursor-pointer bg-white hover:bg-gray-200 text-gray-950 transition-colors" %>
          <% end %>
        <% else %>
          <div data-controller="modal" class="w-full mt-auto">
            <button data-action="click->modal#open"
                    class="w-full py-2 rounded text-center text-sm font-medium bg-white hover:bg-gray-200 text-gray-950 transition-colors">
              <%= t("plans.one_shot.access_now") %>
            </button>
            <%= render "layouts/login_modal" %>
          </div>
        <% end %>
      </div>

      <%# Right card: Pro (worker plan with billing toggle) %>
      <div class="rounded-xl border border-blue-500 bg-gray-900 p-6 flex flex-col relative <%= is_current_worker ? 'ring-2 ring-blue-500' : '' %>" data-controller="billing-toggle">
        <% unless is_current_worker %>
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs bg-blue-600 text-white px-3 py-0.5 rounded-full font-medium"><%= t("plans.most_popular") %></span>
        <% end %>

        <div class="mb-4">
          <div class="flex items-center gap-2 mb-1">
            <h2 class="text-lg font-bold text-white"><%= t("plans.pro.name") %></h2>
            <% if is_current_worker %>
              <span class="text-xs bg-blue-600 text-white px-2 py-0.5 rounded-full font-medium"><%= t("plans.current_plan") %></span>
            <% end %>
          </div>
          <p class="text-sm text-gray-400"><%= t("plans.pro.description") %></p>
        </div>

        <%# Billing cycle toggle inside the card %>
        <div class="flex mb-4">
          <div class="inline-flex rounded-lg border border-gray-700 p-0.5 bg-gray-800">
            <button data-action="click->billing-toggle#selectMonthly"
                    data-billing-toggle-target="monthlyBtn"
                    class="px-3 py-1 rounded-md text-xs font-medium transition-colors bg-blue-600 text-white">
              <%= t("plans.monthly") %>
            </button>
            <button data-action="click->billing-toggle#selectYearly"
                    data-billing-toggle-target="yearlyBtn"
                    class="px-3 py-1 rounded-md text-xs font-medium transition-colors bg-transparent text-gray-400">
              <%= t("plans.yearly") %>
              <span class="ml-0.5 text-xs text-green-400"><%= t("plans.yearly_save") %></span>
            </button>
          </div>
        </div>

        <%# Pricing %>
        <div class="mb-6">
          <div data-billing-toggle-target="monthlyPrice">
            <span class="text-3xl font-bold text-white"><%= number_with_precision(worker_config[:prices][:monthly][:amount] / 100.0, precision: 2, strip_insignificant_zeros: true) %>&euro;</span>
            <span class="text-gray-400 text-sm"><%= t("plans.tax_label") %> / <%= t("plans.month") %></span>
          </div>
          <div data-billing-toggle-target="yearlyPrice" class="hidden">
            <span class="text-3xl font-bold text-white"><%= number_with_precision(worker_config[:prices][:yearly][:amount] / 100.0, precision: 2, strip_insignificant_zeros: true) %>&euro;</span>
            <span class="text-gray-400 text-sm"><%= t("plans.tax_label") %> / <%= t("plans.year") %></span>
            <div class="text-xs text-gray-500 mt-1">
              <%= number_with_precision(worker_config[:prices][:yearly][:amount] / 1200.0, precision: 2, strip_insignificant_zeros: true) %>&euro; <%= t("plans.tax_label") %> / <%= t("plans.month") %>
            </div>
          </div>
        </div>

        <%# Features list %>
        <ul class="space-y-3 flex-1 mb-6">
          <li class="flex items-center gap-3 text-sm">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span>
              <strong class="text-white"><%= t("plans.unlimited") %></strong>
              <%= t("plans.pieces_per_project") %>
            </span>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            <span>
              <strong class="text-white"><%= t("plans.unlimited") %></strong>
              <%= t("plans.active_projects") %>
            </span>
          </li>
          <% paid_only_features.each do |feature| %>
            <li class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <span class="text-gray-300"><%= t("plans.features.#{feature}") %></span>
            </li>
          <% end %>
        </ul>

        <%# Action button %>
        <% if is_current_worker && user_signed_in? && current_user.stripe_subscription_id.present? %>
          <%= button_to t("plans.manage_subscription"),
                plan_portal_path,
                method: :post,
                class: "w-full py-2 rounded text-center text-sm font-medium bg-gray-700 hover:bg-gray-600 text-white transition-colors" %>
        <% elsif is_current_worker %>
          <div class="w-full py-2 rounded text-center text-sm font-medium bg-gray-800 text-gray-400 cursor-default">
            <%= t("plans.current_plan") %>
          </div>
        <% elsif user_signed_in? %>
          <%= form_with url: plan_checkout_path, method: :post, class: "w-full" do |f| %>
            <%= f.hidden_field :plan, value: "worker" %>
            <%= f.hidden_field :billing_cycle, value: "monthly", data: { billing_toggle_target: "billingCycleInput" } %>
            <%= f.submit t("plans.subscribe"),
                  class: "w-full py-2 rounded text-center text-sm font-medium cursor-pointer bg-blue-600 hover:bg-blue-500 text-white transition-colors" %>
          <% end %>
        <% else %>
          <div data-controller="modal">
            <button data-action="click->modal#open"
                    class="w-full py-2 rounded text-center text-sm font-medium bg-blue-600 hover:bg-blue-500 text-white transition-colors">
              <%= t("plans.subscribe") %>
            </button>
            <%= render "layouts/login_modal" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
