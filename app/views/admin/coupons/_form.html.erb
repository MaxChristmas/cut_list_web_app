<%= form_with(model: [:admin, coupon], class: "space-y-4") do |f| %>
  <% if coupon.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3">
      <ul class="list-disc list-inside text-sm text-red-800">
        <% coupon.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% unless coupon.persisted? %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Code <span class="font-normal text-gray-400">(leave blank to auto-generate)</span></label>
      <%= f.text_field :code, maxlength: 6, placeholder: "e.g. A3F2B1", class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  <% end %>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Plan</label>
    <%= f.select :plan, %w[worker enterprise], {}, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Duration (days)</label>
    <%= f.number_field :duration_days, min: 1, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Expires At <span class="font-normal text-gray-400">(leave blank for no expiration)</span></label>
    <%= f.datetime_local_field :expires_at, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Max Uses <span class="font-normal text-gray-400">(leave blank for unlimited)</span></label>
    <%= f.number_field :max_uses, min: 1, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <% if coupon.persisted? %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Code</label>
      <% if coupon.uses_count == 0 %>
        <%= f.text_field :code, maxlength: 6, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% else %>
        <div class="flex items-center gap-2">
          <div class="text-sm font-mono text-gray-900 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2"><%= coupon.code %></div>
          <span class="text-xs text-gray-400">Used — cannot be changed</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="flex gap-3">
    <%= f.submit class: "bg-blue-600 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_coupons_path, class: "bg-white border border-gray-300 rounded-lg px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
<% end %>
