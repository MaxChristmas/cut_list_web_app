<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-semibold text-gray-900">Coupons</h2>
  <%= link_to "New Coupon", new_admin_coupon_path, class: "bg-blue-600 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Code</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plan</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Uses</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Expires</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @coupons.each do |coupon| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm font-mono font-medium text-gray-900"><%= coupon.code %></td>
          <td class="px-5 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= coupon.plan == 'worker' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
              <%= coupon.plan %>
            </span>
          </td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= pluralize(coupon.duration_days, "day") %></td>
          <td class="px-5 py-3 text-sm text-gray-500">
            <%= coupon.uses_count %><%= coupon.max_uses ? " / #{coupon.max_uses}" : "" %>
          </td>
          <td class="px-5 py-3 text-sm text-gray-500">
            <%= coupon.expires_at ? coupon.expires_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") : "Never" %>
          </td>
          <td class="px-5 py-3">
            <% if coupon.redeemable? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Active</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">Inactive</span>
            <% end %>
          </td>
          <td class="px-5 py-3 text-right">
            <%= link_to "View", admin_coupon_path(coupon), class: "text-sm text-blue-600 hover:text-blue-800" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination %>
