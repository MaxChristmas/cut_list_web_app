<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-semibold text-gray-900">Users</h2>
  <%= link_to "New User", new_admin_user_path, class: "bg-blue-600 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-blue-700" %>
</div>

<%= form_tag admin_users_path, method: :get, class: "mb-4 flex justify-end items-center gap-3" do %>
  <input type="hidden" name="sort" value="<%= @sort %>">
  <input type="hidden" name="direction" value="<%= @sort_direction %>">
  <div class="flex items-center gap-2">
    <label for="plan" class="text-sm font-medium text-gray-700">Plan:</label>
    <select name="plan" id="plan" onchange="this.form.submit()"
      class="rounded-lg border-gray-300 text-sm py-1.5 pl-3 pr-8 focus:border-blue-500 focus:ring-blue-500">
      <option value="all" <%= "selected" if @plan_filter == "all" %>>All plans</option>
      <% Plannable::PLANS.each_key do |plan| %>
        <option value="<%= plan %>" <%= "selected" if @plan_filter == plan %>><%= plan.capitalize %></option>
      <% end %>
    </select>
  </div>
  <div class="flex items-center gap-2">
    <label for="score" class="text-sm font-medium text-gray-700">Score:</label>
    <select name="score" id="score" onchange="this.form.submit()"
      class="rounded-lg border-gray-300 text-sm py-1.5 pl-3 pr-8 focus:border-blue-500 focus:ring-blue-500">
      <% Admin::UsersController::SCORE_RANGES.each do |key, label, _| %>
        <option value="<%= key %>" <%= "selected" if @score_filter == key %>><%= label %></option>
      <% end %>
    </select>
  </div>
<% end %>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Plan</th>
        <th class="px-5 py-3 text-left text-xs font-medium uppercase">
          <%= link_to admin_users_path(sort: "projects_count", direction: @sort == "projects_count" && @sort_direction == "desc" ? "asc" : "desc", plan: @plan_filter, score: @score_filter),
              class: "inline-flex items-center gap-1 #{@sort == 'projects_count' ? 'text-gray-900' : 'text-gray-500 hover:text-gray-700'}" do %>
            Projects
            <% if @sort == "projects_count" %>
              <span class="text-gray-900"><%= @sort_direction == "asc" ? "▲" : "▼" %></span>
            <% else %>
              <span class="text-gray-400">◇</span>
            <% end %>
          <% end %>
        </th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Optimizations</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Score</th>
        <th class="px-5 py-3 text-left text-xs font-medium uppercase">
          <%= link_to admin_users_path(sort: "created_at", direction: @sort == "created_at" && @sort_direction == "desc" ? "asc" : "desc", plan: @plan_filter, score: @score_filter),
              class: "inline-flex items-center gap-1 #{@sort == 'created_at' ? 'text-gray-900' : 'text-gray-500 hover:text-gray-700'}" do %>
            Created
            <% if @sort == "created_at" %>
              <span class="text-gray-900"><%= @sort_direction == "asc" ? "▲" : "▼" %></span>
            <% else %>
              <span class="text-gray-400">◇</span>
            <% end %>
          <% end %>
        </th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-900">
            <%= link_to user.email, admin_user_path(user), class: "text-blue-600 hover:text-blue-800" %>
            <% if user.internal? %>
              <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Internal</span>
            <% end %>
            <% if user.discarded? %>
              <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Soft Deleted</span>
            <% end %>
          </td>
          <td class="px-5 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= user.plan == 'free' ? 'bg-gray-100 text-gray-700' : user.plan == 'worker' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
              <%= user.plan %>
            </span>
          </td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= user.projects.size %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= user.projects.sum(:optimizations_count) %></td>
          <td class="px-5 py-3 text-sm">
            <% score = user.engagement_score %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= score >= 60 ? 'bg-green-100 text-green-700' : score >= 30 ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600' %>">
              <%= score %>/100
            </span>
          </td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= user.created_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") %></td>
          <td class="px-5 py-3 text-right">
            <%= link_to "View", admin_user_path(user), class: "text-sm text-blue-600 hover:text-blue-800" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= admin_pagination %>
