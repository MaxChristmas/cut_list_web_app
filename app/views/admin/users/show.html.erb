<div class="mb-6">
  <%= link_to "&larr; Back to Users".html_safe, admin_users_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
</div>

<div class="flex justify-between items-start mb-6">
  <div class="flex items-center gap-3">
    <h2 class="text-2xl font-semibold text-gray-900"><%= @user.email %></h2>
    <% if @user.internal? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Internal</span>
    <% end %>
    <% if @user.discarded? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Soft Deleted</span>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_admin_user_path(@user), class: "bg-white border border-gray-300 rounded-lg px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% unless @user.discarded? %>
      <%= link_to "Soft Delete", soft_delete_admin_user_path(@user), data: { turbo_method: :patch, turbo_confirm: "This will anonymize the user's data and lock their account. Continue?" }, class: "bg-orange-500 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-orange-600" %>
    <% end %>
    <%= link_to "Hard Delete", admin_user_path(@user), data: { turbo_method: :delete, turbo_confirm: "This will PERMANENTLY delete this user and all their data. This cannot be undone. Are you sure?" }, class: "bg-red-600 text-white rounded-lg px-4 py-2 text-sm font-medium hover:bg-red-700" %>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-5 mb-6">
  <dl class="grid grid-cols-2 gap-4">
    <div>
      <dt class="text-sm font-medium text-gray-500">Plan</dt>
      <dd class="mt-1 text-sm text-gray-900 capitalize"><%= @user.plan %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Plan Expires At</dt>
      <dd class="mt-1 text-sm text-gray-900">
        <% if @user.plan_expires_at.present? %>
          <%= @user.plan_expires_at.strftime("%b %d, %Y at %H:%M") %>
          <% if @user.plan_expired? %>
            <span class="ml-1 text-xs text-red-600 font-medium">Expired</span>
          <% end %>
        <% else %>
          <span class="text-gray-400">No expiration</span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Provider</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.provider.presence || "Email" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Stripe Customer</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.stripe_customer_id.presence || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Sign-in Count</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.sign_in_count %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Last Sign-in At</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_at&.strftime("%b %d, %Y at %H:%M") || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Created</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime("%b %d, %Y at %H:%M") %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Last Sign-in IP</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_ip.presence || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Device</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_device&.capitalize || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Location</dt>
      <dd class="mt-1 text-sm text-gray-900">
        <% if @user.last_sign_in_city.present? || @user.last_sign_in_country.present? %>
          <%= [@user.last_sign_in_city, @user.last_sign_in_country].compact_blank.join(", ") %>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
  </dl>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-5 mb-6">
  <h3 class="text-lg font-medium text-gray-900 mb-3">Engagement Score</h3>
  <% breakdown = @user.engagement_score_breakdown %>
  <% total = @user.engagement_score %>
  <div class="mb-4">
    <div class="flex items-center gap-3">
      <div class="flex-1 bg-gray-200 rounded-full h-4 overflow-hidden">
        <div class="h-4 rounded-full <%= total >= 60 ? 'bg-green-500' : total >= 30 ? 'bg-yellow-500' : 'bg-gray-400' %>" style="width: <%= total %>%"></div>
      </div>
      <span class="text-lg font-semibold text-gray-900 w-16 text-right"><%= total %>/100</span>
    </div>
  </div>
  <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div>
      <dt class="text-sm font-medium text-gray-500">Plan (<%= Scorable::SCORE_WEIGHTS[:plan] %> max)</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= breakdown[:plan] %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Sign-ins (<%= Scorable::SCORE_WEIGHTS[:sign_ins] %> max)</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= breakdown[:sign_ins] %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Projects (<%= Scorable::SCORE_WEIGHTS[:projects] %> max)</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= breakdown[:projects] %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Optimizations (<%= Scorable::SCORE_WEIGHTS[:optimizations] %> max)</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= breakdown[:optimizations] %></dd>
    </div>
  </dl>
</div>

<h3 class="text-lg font-medium text-gray-900 mb-3">Projects (<%= @projects.size %>)</h3>
<% if @projects.any? %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sheet Size</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @projects.each do |project| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 text-sm text-gray-900"><%= project.display_name %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= project.sheet_width %> x <%= project.sheet_length %></td>
            <td class="px-5 py-3 text-sm">
              <% if project.archived? %>
                <span class="text-gray-400">Archived</span>
              <% else %>
                <span class="text-green-600">Active</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= project.created_at.strftime("%b %d, %Y at %H:%M") %></td>
            <td class="px-5 py-3 text-right">
              <%= link_to "View", admin_project_path(project), class: "text-sm text-blue-600 hover:text-blue-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-sm text-gray-500">No projects.</div>
<% end %>
