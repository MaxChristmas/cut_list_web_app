<div class="mb-6">
  <%= link_to "&larr; Back to feedbacks".html_safe, admin_feedbacks_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-xl font-semibold text-gray-900">Feedback #<%= @feedback.id %></h2>
  </div>

  <div class="px-6 py-5 space-y-5">
    <%# User info %>
    <div>
      <h3 class="text-xs font-medium text-gray-500 uppercase mb-1">User</h3>
      <% if @feedback.user %>
        <%= link_to @feedback.user.email, admin_user_path(@feedback.user), class: "text-blue-600 hover:text-blue-800" %>
        <span class="text-sm text-gray-500 ml-2">(<%= @feedback.user.projects.count %> projects)</span>
      <% else %>
        <span class="text-gray-400">Deleted user</span>
      <% end %>
    </div>

    <%# Rating %>
    <div>
      <h3 class="text-xs font-medium text-gray-500 uppercase mb-1">Rating</h3>
      <div class="flex items-center gap-2">
        <div class="flex">
          <% (1..5).each do |i| %>
            <svg class="w-5 h-5 <%= i <= @feedback.rating ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          <% end %>
        </div>
        <span class="text-sm text-gray-700"><%= @feedback.rating %>/5</span>
      </div>
    </div>

    <%# Improvement %>
    <div>
      <h3 class="text-xs font-medium text-gray-500 uppercase mb-1">What could be improved?</h3>
      <% if @feedback.improvement.present? %>
        <p class="text-sm text-gray-900 bg-gray-50 rounded-lg p-3"><%= @feedback.improvement %></p>
      <% else %>
        <p class="text-sm text-gray-400 italic">Not answered</p>
      <% end %>
    </div>

    <%# Feature request %>
    <div>
      <h3 class="text-xs font-medium text-gray-500 uppercase mb-1">Feature request</h3>
      <% if @feedback.feature_request.present? %>
        <p class="text-sm text-gray-900 bg-gray-50 rounded-lg p-3"><%= @feedback.feature_request %></p>
      <% else %>
        <p class="text-sm text-gray-400 italic">Not answered</p>
      <% end %>
    </div>

    <%# Date %>
    <div>
      <h3 class="text-xs font-medium text-gray-500 uppercase mb-1">Submitted</h3>
      <p class="text-sm text-gray-700"><%= @feedback.created_at.in_time_zone("Europe/Paris").strftime("%B %d, %Y at %H:%M") %></p>
    </div>
  </div>
</div>
