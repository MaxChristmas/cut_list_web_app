<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
  <h2 class="text-2xl font-semibold text-gray-900">Feedbacks</h2>
  <% if @average_rating %>
    <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-2">
      <div class="flex">
        <% (1..5).each do |i| %>
          <svg class="w-5 h-5 <%= i <= @average_rating.round ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        <% end %>
      </div>
      <span class="text-sm font-medium text-gray-700"><%= @average_rating %>/5</span>
      <span class="text-sm text-gray-500">(<%= @total_count %> feedback<%= @total_count > 1 ? 's' : '' %>)</span>
    </div>
  <% end %>
</div>

<% if @feedbacks.any? %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Rating</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Improvement</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Feature Request</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Score</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Projects</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @feedbacks.each do |feedback| %>
          <tr class="<%= feedback.read_at.nil? ? 'bg-gray-50 hover:bg-gray-100' : 'hover:bg-gray-50' %>">
            <td class="px-5 py-3 text-sm">
              <% if feedback.user %>
                <%= link_to feedback.user.email, admin_user_path(feedback.user), class: "text-blue-600 hover:text-blue-800" %>
              <% else %>
                <span class="text-gray-400">Deleted</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-sm">
              <div class="flex">
                <% (1..5).each do |i| %>
                  <svg class="w-4 h-4 <%= i <= feedback.rating ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-3 text-sm text-gray-900"><%= truncate(feedback.improvement, length: 60) %></td>
            <td class="px-5 py-3 text-sm text-gray-900"><%= truncate(feedback.feature_request, length: 60) %></td>
            <td class="px-5 py-3 text-sm">
              <% if feedback.user %>
                <% score = feedback.user.engagement_score %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= score >= 70 ? 'bg-green-100 text-green-800' : score >= 40 ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= score %>
                </span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= feedback.user&.projects&.count || 0 %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= feedback.created_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") %></td>
            <td class="px-5 py-3 text-right whitespace-nowrap">
              <%= link_to "View", admin_feedback_path(feedback), class: "text-sm text-blue-600 hover:text-blue-800" %>
              <%= button_to "Delete", admin_feedback_path(feedback), method: :delete, data: { turbo_confirm: "Delete this feedback?" }, class: "text-sm text-red-600 hover:text-red-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-sm text-gray-500">No feedbacks yet.</div>
<% end %>

<%= admin_pagination %>
