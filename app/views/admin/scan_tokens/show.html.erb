<div class="mb-6">
  <%= link_to "&larr; Back to Scan Tokens".html_safe, admin_scan_tokens_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
</div>

<h2 class="text-2xl font-semibold text-gray-900 mb-6">Scan Token #<%= @scan_token.id %></h2>

<div class="flex gap-6 mb-6">
  <div class="flex-1 bg-white rounded-lg border border-gray-200 p-5">
    <dl class="grid grid-cols-2 gap-4">
      <div>
        <dt class="text-sm font-medium text-gray-500">User</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <% if @scan_token.user %>
            <%= link_to @scan_token.user.email, admin_user_path(@scan_token.user), class: "text-blue-600 hover:text-blue-800" %>
          <% else %>
            —
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @scan_token.status.capitalize %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Token</dt>
        <dd class="mt-1 text-sm text-gray-500 font-mono text-xs break-all"><%= @scan_token.token %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Expires at</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @scan_token.expires_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Created</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @scan_token.created_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Agent</dt>
        <dd class="mt-1 text-sm">
          <% if @scan_token.image_type.present? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800"><%= @scan_token.image_type %></span>
          <% else %>
            <span class="text-gray-400">—</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Tokens</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <% if @scan_token.input_tokens.present? %>
            <span class="text-gray-500">in:</span> <%= number_with_delimiter(@scan_token.input_tokens) %>
            <span class="text-gray-400 mx-1">|</span>
            <span class="text-gray-500">out:</span> <%= number_with_delimiter(@scan_token.output_tokens) %>
            <span class="text-gray-400 mx-1">|</span>
            <span class="text-gray-500">total:</span> <%= number_with_delimiter(@scan_token.input_tokens + @scan_token.output_tokens) %>
          <% else %>
            <span class="text-gray-400">—</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Cost</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <% if @scan_token.cost_usd.present? %>
            $<%= @scan_token.cost_usd %> USD
          <% else %>
            <span class="text-gray-400">—</span>
          <% end %>
        </dd>
      </div>
    </dl>
  </div>

  <div class="flex-1 bg-white rounded-lg border border-gray-200 p-5">
    <% if @scan_token.photo.attached? %>
      <div class="flex gap-5">
        <div class="shrink-0">
          <%= image_tag @scan_token.photo, class: "max-h-56 rounded-lg shadow-sm" %>
        </div>
        <div class="flex-1 flex flex-col justify-between">
          <dl class="space-y-3">
            <div>
              <dt class="text-xs font-medium text-gray-500">Filename</dt>
              <dd class="mt-0.5 text-sm text-gray-900"><%= @scan_token.photo.filename %></dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-gray-500">Content type</dt>
              <dd class="mt-0.5 text-sm text-gray-900"><%= @scan_token.photo.content_type %></dd>
            </div>
            <div>
              <dt class="text-xs font-medium text-gray-500">Size</dt>
              <dd class="mt-0.5 text-sm text-gray-900"><%= number_to_human_size(@scan_token.photo.byte_size) %></dd>
            </div>
            <% if @scan_token.photo.analyzed? && @scan_token.photo.metadata[:width] %>
              <div>
                <dt class="text-xs font-medium text-gray-500">Dimensions</dt>
                <dd class="mt-0.5 text-sm text-gray-900"><%= @scan_token.photo.metadata[:width] %> × <%= @scan_token.photo.metadata[:height] %> px</dd>
              </div>
            <% end %>
          </dl>
          <div class="mt-4">
            <%= link_to rails_blob_path(@scan_token.photo, disposition: "attachment"),
                  class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 text-gray-700 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
              </svg>
              Download
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 text-center py-8">No photo attached</p>
    <% end %>
  </div>
</div>

<% if @scan_token.result.present? %>
  <% pieces = @scan_token.result.is_a?(Array) ? @scan_token.result : [] %>
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-lg font-medium text-gray-900">Extracted Pieces (<%= pieces.size %>)</h3>
    <% if pieces.any? %>
      <%
        csv_data = "length,width,quantity\n" + pieces.map { |p| "#{p["longueur"]},#{p["largeur"]},#{p["quantite"] || 1}" }.join("\n")
        csv_b64 = Base64.strict_encode64(csv_data)
      %>
      <a href="data:text/csv;base64,<%= csv_b64 %>" download="scan_<%= @scan_token.id %>_pieces.csv"
         class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 text-gray-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
        </svg>
        Export CSV
      </a>
    <% end %>
  </div>
  <% if pieces.any? %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Length (mm)</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Width (mm)</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Qty</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Material</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Confidence</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% pieces.each do |piece| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 text-sm text-gray-900"><%= piece["nom"] %></td>
              <td class="px-5 py-3 text-sm text-gray-500"><%= piece["longueur"] %></td>
              <td class="px-5 py-3 text-sm text-gray-500"><%= piece["largeur"] %></td>
              <td class="px-5 py-3 text-sm text-gray-500"><%= piece["quantite"] %></td>
              <td class="px-5 py-3 text-sm text-gray-500"><%= piece["materiau"] || "—" %></td>
              <td class="px-5 py-3 text-sm">
                <% case piece["confiance"] %>
                <% when "haute" %>
                  <span class="text-green-600"><%= piece["confiance"] %></span>
                <% when "moyenne" %>
                  <span class="text-yellow-600"><%= piece["confiance"] %></span>
                <% else %>
                  <span class="text-red-600"><%= piece["confiance"] %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-sm text-gray-500">No pieces extracted.</div>
  <% end %>
<% end %>

<% report = @scan_token.accuracy_report %>
<% if report %>
  <h3 class="text-lg font-medium text-gray-900 mb-3 mt-8">Accuracy Report</h3>
  <div class="bg-white rounded-lg border border-gray-200 p-5 mb-6">
    <div class="grid grid-cols-6 gap-4 mb-6">
      <div class="text-center p-3 rounded-lg bg-gray-50">
        <div class="text-2xl font-bold <%= report[:accuracy_pct] >= 80 ? 'text-green-600' : report[:accuracy_pct] >= 50 ? 'text-yellow-600' : 'text-red-600' %>">
          <%= report[:accuracy_pct] %>%
        </div>
        <div class="text-xs text-gray-500 mt-1">Accuracy</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-green-50">
        <div class="text-2xl font-bold text-green-600"><%= report[:exact_matches] %></div>
        <div class="text-xs text-gray-500 mt-1">Exact</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-yellow-50">
        <div class="text-2xl font-bold text-yellow-600"><%= report[:close_matches] %></div>
        <div class="text-xs text-gray-500 mt-1">Close (&le;10mm)</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-red-50">
        <div class="text-2xl font-bold text-red-600"><%= report[:wrong] %></div>
        <div class="text-xs text-gray-500 mt-1">Wrong</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-blue-50">
        <div class="text-2xl font-bold text-blue-600"><%= report[:added_by_user].size %></div>
        <div class="text-xs text-gray-500 mt-1">Added</div>
      </div>
      <div class="text-center p-3 rounded-lg bg-orange-50">
        <div class="text-2xl font-bold text-orange-600"><%= report[:removed_by_user].size %></div>
        <div class="text-xs text-gray-500 mt-1">Removed</div>
      </div>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Piece</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">AI Length</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">User Length</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">AI Width</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">User Width</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">AI Qty</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">User Qty</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <%# Matched pieces %>
        <% report[:matched].each do |m| %>
          <% l_ok = m[:ai][:l] == m[:user][:l] %>
          <% w_ok = m[:ai][:w] == m[:user][:w] %>
          <% q_ok = m[:ai][:q] == m[:user][:q] %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2 text-sm text-gray-900"><%= m[:user][:label] %></td>
            <td class="px-4 py-2 text-sm <%= l_ok ? 'text-gray-500' : 'text-red-600 font-medium' %>"><%= m[:ai][:l].to_i %></td>
            <td class="px-4 py-2 text-sm <%= l_ok ? 'text-gray-500' : 'text-green-600 font-medium' %>"><%= m[:user][:l].to_i %></td>
            <td class="px-4 py-2 text-sm <%= w_ok ? 'text-gray-500' : 'text-red-600 font-medium' %>"><%= m[:ai][:w].to_i %></td>
            <td class="px-4 py-2 text-sm <%= w_ok ? 'text-gray-500' : 'text-green-600 font-medium' %>"><%= m[:user][:w].to_i %></td>
            <td class="px-4 py-2 text-sm <%= q_ok ? 'text-gray-500' : 'text-red-600 font-medium' %>"><%= m[:ai][:q] %></td>
            <td class="px-4 py-2 text-sm <%= q_ok ? 'text-gray-500' : 'text-green-600 font-medium' %>"><%= m[:user][:q] %></td>
            <td class="px-4 py-2 text-sm">
              <% if m[:diff_score] == 0 %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Exact</span>
              <% elsif m[:diff_score] <= 10 %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Close</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Wrong</span>
              <% end %>
            </td>
          </tr>
        <% end %>

        <%# Pieces added by user (not in AI output) %>
        <% report[:added_by_user].each do |p| %>
          <tr class="bg-blue-50/50 hover:bg-blue-50">
            <td class="px-4 py-2 text-sm text-gray-900"><%= p[:label] %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm text-blue-600 font-medium"><%= p[:l].to_i %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm text-blue-600 font-medium"><%= p[:w].to_i %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm text-blue-600 font-medium"><%= p[:q] %></td>
            <td class="px-4 py-2 text-sm">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Added</span>
            </td>
          </tr>
        <% end %>

        <%# Pieces removed by user (in AI output but not submitted) %>
        <% report[:removed_by_user].each do |p| %>
          <tr class="bg-orange-50/50 hover:bg-orange-50">
            <td class="px-4 py-2 text-sm text-gray-900 line-through"><%= p[:label] %></td>
            <td class="px-4 py-2 text-sm text-orange-600 line-through"><%= p[:l].to_i %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm text-orange-600 line-through"><%= p[:w].to_i %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm text-orange-600 line-through"><%= p[:q] %></td>
            <td class="px-4 py-2 text-sm text-gray-300">—</td>
            <td class="px-4 py-2 text-sm">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-100 text-orange-800">Removed</span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
