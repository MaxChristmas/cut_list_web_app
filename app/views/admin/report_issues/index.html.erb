<div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
  <h2 class="text-2xl font-semibold text-gray-900">Reports</h2>
  <nav class="inline-flex rounded-lg border border-gray-200 bg-white overflow-hidden text-sm">
    <% [ [ "untreated", "Untreated" ], [ "treated", "Treated" ], [ "all", "All" ] ].each_with_index do |(value, label), i| %>
      <% active = @status == value %>
      <%= link_to label, url_for(status: value, page: nil), class: "px-3 py-1.5 #{'bg-gray-100 text-gray-900 font-medium' if active} #{'text-gray-600 hover:bg-gray-50' unless active} #{'border-l border-gray-200' if i > 0}" %>
    <% end %>
  </nav>
</div>

<% if @report_issues.any? %>
  <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Body</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Page URL</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @report_issues.each do |report| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 text-sm">
              <% if report.treated? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Treated</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">Untreated</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500">
              <% if report.user %>
                <%= link_to report.user.email, admin_user_path(report.user), class: "text-blue-600 hover:text-blue-800" %>
              <% else %>
                <span class="text-gray-400">Guest</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-900"><%= truncate(report.body, length: 80) %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= truncate(report.page_url, length: 40) %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= report.created_at.in_time_zone("Europe/Paris").strftime("%b %d, %Y at %H:%M") %></td>
            <td class="px-5 py-3 text-right flex gap-3 justify-end">
              <%= link_to "View", admin_report_issue_path(report), class: "text-sm text-blue-600 hover:text-blue-800" %>
              <%= button_to "Delete", admin_report_issue_path(report), method: :delete, data: { turbo_confirm: "Delete this report?" }, class: "text-sm text-red-600 hover:text-red-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-sm text-gray-500">No reports.</div>
<% end %>

<%= admin_pagination %>
