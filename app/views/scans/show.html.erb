<% if @error %>
  <div class="text-center space-y-4">
    <div class="w-16 h-16 mx-auto rounded-full bg-red-900/50 flex items-center justify-center">
      <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </div>
    <h2 class="text-lg font-semibold text-red-400"><%= t("scan.expired_title") %></h2>
    <p class="text-sm text-gray-400"><%= t("scan.expired_message") %></p>
  </div>
<% else %>
  <div data-controller="scan-upload" class="space-y-6">
    <div class="text-center space-y-2">
      <div class="w-16 h-16 mx-auto rounded-full bg-blue-900/50 flex items-center justify-center">
        <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold"><%= t("scan.title") %></h2>
      <p class="text-sm text-gray-400"><%= t("scan.instruction") %></p>
    </div>

    <%= form_with url: scan_upload_path(@scan_token.token), method: :post, multipart: true,
                  data: { turbo: false, "scan-upload-target": "form", action: "submit->scan-upload#submit" } do %>
      <input type="file" name="photo" accept="image/*" capture="environment"
             data-scan-upload-target="fileInput"
             data-action="change->scan-upload#fileSelected"
             class="hidden">

      <button type="button" data-action="scan-upload#openCamera"
              data-scan-upload-target="cameraButton"
              class="w-full py-4 px-6 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold text-lg transition-colors">
        <%= t("scan.take_photo") %>
      </button>
    <% end %>

    <div data-scan-upload-target="spinner" class="hidden text-center space-y-3">
      <div class="inline-block w-8 h-8 border-2 border-blue-400 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm text-gray-400"><%= t("scan.uploading") %></p>
    </div>

    <div data-scan-upload-target="error" class="hidden p-3 bg-red-900/50 text-red-300 rounded text-sm text-center"></div>
  </div>
<% end %>
